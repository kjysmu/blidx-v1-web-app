APP_NAME=Blidx Backend
ENVIRONMENT=local
DEBUG=true

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/blidx
USE_DATABASE_STORAGE=false

# Use a unique random value of at least 32 characters outside local development.
JWT_SECRET_KEY=change_this_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_MAX_FAILED_ATTEMPTS=8
AUTH_LOCKOUT_MINUTES=15
LOGIN_RATE_LIMIT_ATTEMPTS=20
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
ACCOUNT_EMAIL_RATE_LIMIT_ATTEMPTS=5
ACCOUNT_EMAIL_RATE_LIMIT_WINDOW_SECONDS=900
ACCOUNT_TOKEN_RESEND_COOLDOWN_SECONDS=60

# Use console only for local testing. Use resend plus a verified sender in production.
EMAIL_PROVIDER=console
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
APP_BASE_URL=http://127.0.0.1:8000
EMAIL_FROM="Blidx <onboarding@resend.dev>"
RESEND_API_KEY=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1200
ANTHROPIC_TEMPERATURE=0.7
OPENAI_API_KEY=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/linkedin/callback
LINKEDIN_SCOPES=openid profile w_member_social
LINKEDIN_API_VERSION=202605
# Use a separate unique random value of at least 32 characters in production.
LINKEDIN_TOKEN_ENCRYPTION_KEY=
LINKEDIN_OAUTH_STATE_EXPIRE_MINUTES=10

SEARCH_API_KEY=

ADMIN_USERNAME=
ADMIN_PASSWORD=
