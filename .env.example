APP_NAME=Blidx Backend
ENVIRONMENT=local
DEBUG=true

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/blidx
USE_DATABASE_STORAGE=false

# Use a unique random value of at least 32 characters outside local development.
JWT_SECRET_KEY=change_this_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1200
ANTHROPIC_TEMPERATURE=0.7
OPENAI_API_KEY=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/linkedin/callback
LINKEDIN_SCOPES=openid profile w_member_social
LINKEDIN_API_VERSION=202605
# Use a separate unique random value of at least 32 characters in production.
LINKEDIN_TOKEN_ENCRYPTION_KEY=
LINKEDIN_OAUTH_STATE_EXPIRE_MINUTES=10

SEARCH_API_KEY=

ADMIN_USERNAME=
ADMIN_PASSWORD=
